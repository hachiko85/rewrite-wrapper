# docker/.env.example
# Docker 環境用の環境変数テンプレート
# Environment variable template for Docker setup
#
# このファイルをプロジェクトルートの .env にコピーして値を設定してください
# Copy this file to project root .env and fill in the values

# ──────────────────────────────────────────
# モデル設定 / Model settings
# ──────────────────────────────────────────

# /models 以下のモデルファイルパス (相対パス)
# Model file path relative to /models mount
MODEL_FILE=Qwen3.5-4B-GGUF/Qwen3.5-4B-UD-Q4_K_XL.gguf

# ホスト側のモデルディレクトリ (コンテナ内 /models にマウントされる)
# Host model directory (mounted as /models inside container)
MODELS_DIR=/path/to/your/gguf_models

# ──────────────────────────────────────────
# llama.cpp 設定 / llama.cpp settings
# ──────────────────────────────────────────

# 同時推論スロット数 / Number of parallel inference slots
N_PARALLEL=4

# コンテキストサイズ (全スロット合計) / Context size (total across all slots)
# N_PARALLEL=4 の場合: 1スロットあたり CTX_SIZE / N_PARALLEL トークン
CTX_SIZE=8192

# GPU レイヤー数 (-1 = 全レイヤーをGPUに) / GPU layers (-1 = all layers to GPU)
N_GPU_LAYERS=-1

# llama.cpp リスニングポート (コンテナ内部) / llama.cpp listen port (inside container)
LLAMA_PORT=8080

# 最大生成トークン数 / Max generated tokens
N_PREDICT=512

# ──────────────────────────────────────────
# ラッパーサーバー / Wrapper server
# ──────────────────────────────────────────

# ラッパーサーバーポート / Wrapper server port
PORT=3000

# ホスト側の公開ポート / Host-side exposed port
WRAPPER_PORT=3000

# 管理APIキー (必ず変更すること) / Master key — MUST CHANGE THIS
MASTER_KEY=your-secret-master-key-change-this

# ──────────────────────────────────────────
# MongoDB 設定 / MongoDB settings
# ──────────────────────────────────────────

# docker-compose では mongodb サービス名で解決される
# In docker-compose, resolved via service name 'mongodb'
MONGO_URI=mongodb://mongodb:27017/k9db

# ホストのMongoDBを使う場合 / When using host MongoDB:
# MONGO_URI=mongodb://host.docker.internal:27017/k9db

MONGO_DB=k9db
MONGO_COLLECTION=api_keys
MONGO_LOGS_COLLECTION=completion_logs
