# ──────────────────────────────────────────────────────────────────────────────
# .env.example
# このファイルをプロジェクトルートに .env としてコピーして値を設定する。
# Copy this file to the project root as .env and fill in your values.
#
#   cp beta-test/raw/.env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── MongoDB ────────────────────────────────────────────────────────────────────
# 接続URI (認証あり) / Connection URI with authentication
# 書式: mongodb://ユーザー名:パスワード@ホスト:ポート/DB名?authSource=admin
MONGO_URI=mongodb://username:password@localhost:27017/k9db?authSource=admin

# データベース名 / Database name (default: k9db)
MONGO_DB=k9db

# APIキーコレクション名 / API keys collection (auto-created on first run)
MONGO_COLLECTION=api_keys

# 完了ログコレクション名 / Completion logs collection (auto-created on first run)
MONGO_LOGS_COLLECTION=completion_logs

# ── ラッパーサーバー / Wrapper server ─────────────────────────────────────────
# 管理APIの認証キー / Master key for admin API (POST /admin/keys etc.)
MASTER_KEY=your-secret-master-key-here

# ラッパーサーバーのリスンポート / Port to listen on (default: 3000)
PORT=3085

# バックエンド設定ファイルのパス / Path to backends config
# プロジェクトルートからの相対パス / Relative from project root
BACKENDS_CONFIG=./beta-test/raw/backends.yaml
